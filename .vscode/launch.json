{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm run dev",
      "cwd": "${workspaceFolder}/apps/server"
    },
    {
      "name": "MCP",
      "type": "node-terminal",
      "request": "launch",
      "command": "MCP_PORT=3030 bun --watch src/index.ts",
      "cwd": "${workspaceFolder}/apps/mcp"
    },
    {
      "name": "Agent Runtime",
      "type": "node-terminal",
      "request": "launch",
      "command": "[ -f .env ] || cp .env.example .env; uv sync --all-packages && uv run --package agno-agent uvicorn agno_agent.main:app --reload --host 0.0.0.0 --port 8000",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Worker (kicker)",
      "type": "node-terminal",
      "request": "launch",
      "command": "uv sync --all-packages && uv run --package payload-worker uvicorn payload_worker.main:app --reload --host 0.0.0.0 --port 8001",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Worker (taskiq)",
      "type": "node-terminal",
      "request": "launch",
      "command": "uv sync --all-packages && uv run --package payload-worker taskiq worker payload_worker.main:broker --reload",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Lint fix",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm lint:fix",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Type check",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm tsc --noEmit",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Test",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm test",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Launch",
      "configurations": ["Server", "MCP", "Agent Runtime", "Worker (kicker)", "Worker (taskiq)"],
      "stopAll": true
    },
    {
      "name": "Eval",
      "configurations": ["Type check", "Lint fix"],
      "stopAll": true
    }
  ]
}
