# Copy to .env for local dev (devcontainer paths/hostnames).
# settings.py reads this automatically when launched from `backend/`.

LOG_LEVEL=DEBUG
APP_NAME=agno-agent

PAYLOAD_URL=http://app:3000
MCP_URL=http://app:3030/mcp

DATABASE_URL=postgresql://db_admin:devsecret@db:5432/payload_agents
DATABASE_SCHEMA=agno

INTERNAL_SECRET=dev
PAYLOAD_SERVICE_TOKEN=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
