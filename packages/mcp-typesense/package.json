{
  "name": "@zetesis/mcp-typesense",
  "version": "0.2.1",
  "description": "Composable MCP (Model Context Protocol) server that exposes Typesense-backed content with taxonomy enrichment, LLM sampling synthesis tools, and pluggable auth.",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf -g {dist,*.tsbuildinfo}",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@toon-format/toon": "^2.1.0",
    "openai": "^4.104.0",
    "typesense": "^2.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "rimraf": "3.0.2",
    "tsdown": "^0.16.5",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": "^9 || ^10"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typesense",
    "search",
    "rag",
    "payload",
    "payloadcms",
    "llm",
    "sampling"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zetesis-Labs/PayloadAgents.git",
    "directory": "packages/mcp-typesense"
  },
  "homepage": "https://github.com/Zetesis-Labs/PayloadAgents/tree/main/packages/mcp-typesense#readme",
  "bugs": {
    "url": "https://github.com/Zetesis-Labs/PayloadAgents/issues"
  },
  "author": {
    "name": "Zetesis - Rubén Garcia",
    "email": "ruben@zetesis.xyz",
    "url": "https://zetesis.xyz"
  },
  "publisher": "front_tribe",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
